// Jenkinsfile для Accounts Service
// Индивидуальный CI/CD pipeline для микросервиса Accounts

pipeline {
    agent any

    tools {
        gradle 'gradle-8.5'
        jdk 'jdk-21'
    }

    environment {
        SERVICE_NAME = 'accounts'
        DOCKER_REGISTRY = 'registry.example.com/bank'
        DOCKER_CREDENTIALS_ID = 'docker-registry-creds'
        KUBECONFIG_CREDENTIALS_ID = 'k8s-kubeconfig'
    }

    parameters {
        choice(
            name: 'DEPLOY_ENV',
            choices: ['none', 'dev', 'staging', 'production'],
            description: 'Окружение для деплоя'
        )
        booleanParam(
            name: 'RUN_TESTS',
            defaultValue: true,
            description: 'Запускать ли тесты'
        )
        booleanParam(
            name: 'RUN_CONTRACT_TESTS',
            defaultValue: true,
            description: 'Запускать ли контрактные тесты'
        )
        string(
            name: 'GIT_COMMIT',
            defaultValue: '',
            description: 'Git commit для сборки'
        )
    }

    options {
        timestamps()
        timeout(time: 1, unit: 'HOURS')
        disableConcurrentBuilds()
        buildDiscarder(logRotator(numToKeepStr: '10'))
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
                script {
                    if (params.GIT_COMMIT) {
                        sh "git checkout ${params.GIT_COMMIT}"
                    }
                    env.BUILD_VERSION = "${env.BUILD_NUMBER}-${env.GIT_COMMIT?.take(7) ?: 'HEAD'}"
                }
            }
        }

        stage('Validate') {
            steps {
                sh './gradlew :accounts:buildEnvironment --no-daemon'
                sh 'helm lint helm/accounts'
            }
        }

        stage('Build') {
            steps {
                sh './gradlew :accounts:build -x test -x contractTest --no-daemon'
            }
        }

        stage('Unit Tests') {
            when {
                expression { return params.RUN_TESTS }
            }
            steps {
                sh './gradlew :accounts:test --no-daemon'
                junit '**/accounts/build/test-results/test/TEST-*.xml'
            }
        }

        stage('Contract Tests') {
            when {
                expression { return params.RUN_CONTRACT_TESTS }
            }
            steps {
                sh './gradlew :accounts:contractTest --no-daemon'
                junit '**/accounts/build/test-results/contractTest/TEST-*.xml'
            }
        }

        stage('Integration Tests') {
            when {
                expression { return params.RUN_TESTS }
            }
            steps {
                script {
                    // Интеграционные тесты требуют PostgreSQL
                    sh './gradlew :accounts:test --tests "*IntegrationTest*" --no-daemon || true'
                }
            }
        }

        stage('Archive') {
            steps {
                archiveArtifacts artifacts: '**/accounts/build/libs/*.jar', allowEmptyArchive: true
            }
        }

        stage('Docker Build & Push') {
            steps {
                script {
                    withDockerRegistry(credentialsId: DOCKER_CREDENTIALS_ID, toolName: 'docker') {
                        sh '''
                            docker build -t ${DOCKER_REGISTRY}/bank-accounts:${BUILD_VERSION} -f Dockerfile . --build-arg SERVICE_NAME=accounts
                            docker tag ${DOCKER_REGISTRY}/bank-accounts:${BUILD_VERSION} ${DOCKER_REGISTRY}/bank-accounts:latest
                            docker push ${DOCKER_REGISTRY}/bank-accounts:${BUILD_VERSION}
                            docker push ${DOCKER_REGISTRY}/bank-accounts:latest
                        '''
                    }
                }
            }
        }

        stage('Deploy') {
            when {
                expression { return params.DEPLOY_ENV != 'none' }
            }
            stages {
                stage('Deploy to Dev') {
                    when {
                        expression { return params.DEPLOY_ENV == 'dev' }
                    }
                    steps {
                        deployToKubernetes('dev')
                    }
                }

                stage('Deploy to Staging') {
                    when {
                        expression { return params.DEPLOY_ENV == 'staging' }
                    }
                    steps {
                        deployToKubernetes('staging')
                    }
                }

                stage('Deploy to Production') {
                    when {
                        expression { return params.DEPLOY_ENV == 'production' }
                    }
                    steps {
                        input message: 'Confirm deployment to PRODUCTION?', ok: 'Deploy'
                        deployToKubernetes('production')
                    }
                }
            }
        }
    }

    post {
        always {
            cleanWs()
        }
        success {
            echo "Accounts service build completed successfully!"
        }
        failure {
            echo "Accounts service build failed!"
        }
    }
}

def deployToKubernetes(String environment) {
    node {
        withKubeConfig([credentialsId: KUBECONFIG_CREDENTIALS_ID, serverUrl: '']) {
            sh """
                echo "Deploying accounts to ${environment}..."
                
                helm upgrade --install accounts helm/accounts \\
                    --namespace bank-${environment} \\
                    --create-namespace \\
                    --set image.repository=${DOCKER_REGISTRY}/bank-accounts \\
                    --set image.tag=${BUILD_VERSION} \\
                    --values helm/values-${environment}.yaml \\
                    --timeout 5m \\
                    --wait \\
                    --atomic
                
                kubectl rollout status deployment/accounts -n bank-${environment} --timeout=300s
            """
        }
    }
}
