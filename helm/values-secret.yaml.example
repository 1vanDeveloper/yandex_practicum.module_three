# ⚠️ СЕКРЕТНЫЙ ФАЙЛ — НЕ КОММИТИТЬ В GIT!
# Используйте этот файл для переопределения чувствительных значений
# Пример использования:
#   helm upgrade --install bank helm/bank -f helm/values-secret.yaml

# Accounts secrets
accounts:
  secrets:
    JWT_SECRET: "your-super-secret-jwt-key-change-in-production"
    DATABASE_PASSWORD: "postgres-super-password-change-me"
    OAUTH2_CLIENT_SECRET: "accounts-secret"
    KEYCLOAK_ISSUER_URI: "http://keycloak:8080/realms/bank"
    KEYCLOAK_JWK_SET_URI: "http://keycloak:8080/realms/bank/protocol/openid-connect/certs"

# Cash secrets
cash:
  secrets:
    DATABASE_PASSWORD: "postgres-super-password-change-me"
    OAUTH2_CLIENT_SECRET: "cash-secret"
    KEYCLOAK_ISSUER_URI: "http://keycloak:8080/realms/bank"
    KEYCLOAK_JWK_SET_URI: "http://keycloak:8080/realms/bank/protocol/openid-connect/certs"

# Transfer secrets
transfer:
  secrets:
    DATABASE_PASSWORD: "postgres-super-password-change-me"
    OAUTH2_CLIENT_SECRET: "transfer-secret"
    KEYCLOAK_ISSUER_URI: "http://keycloak:8080/realms/bank"
    KEYCLOAK_JWK_SET_URI: "http://keycloak:8080/realms/bank/protocol/openid-connect/certs"

# Notifications secrets
notifications:
  secrets:
    DATABASE_PASSWORD: "postgres-super-password-change-me"
    KEYCLOAK_ISSUER_URI: "http://keycloak:8080/realms/bank"
    KEYCLOAK_JWK_SET_URI: "http://keycloak:8080/realms/bank/protocol/openid-connect/certs"

# Gateway secrets
gateway:
  secrets:
    JWT_SECRET: "your-super-secret-jwt-key-change-in-production"
    OAUTH2_CLIENT_SECRET: "gateway-secret"
    KEYCLOAK_ISSUER_URI: "http://keycloak:8080/realms/bank"
    KEYCLOAK_JWK_SET_URI: "http://keycloak:8080/realms/bank/protocol/openid-connect/certs"

# Frontend secrets
frontend:
  secrets:
    JWT_SECRET: "your-super-secret-jwt-key-change-in-production"
    OAUTH2_CLIENT_SECRET: "frontend-secret"
    KEYCLOAK_ISSUER_URI: "http://keycloak:8080/realms/bank"
    KEYCLOAK_JWK_SET_URI: "http://keycloak:8080/realms/bank/protocol/openid-connect/certs"

# PostgreSQL secrets
postgresql:
  postgresql:
    password: "postgres-super-password-change-me"

# Keycloak secrets
keycloak:
  keycloak:
    adminPassword: "admin-password-change-me"
