# ⚠️ ШАБЛОН ФАЙЛА СЕКРЕТОВ — СКОПИРУЙТЕ В values-secret.yaml И ЗАПОЛНИТЕ
# Этот файл НЕ содержит реальных секретов — только структуру для заполнения
#
# Использование:
#   cp values-secret.yaml.example values-secret.yaml
#   # Отредактируйте values-secret.yaml с реальными секретами
#   helm upgrade --install bank helm/bank -f values-secret.yaml
#
# ⚠️ values-secret.yaml добавлен в .gitignore — НЕ КОММИТЬТЕ ЕГО!

# Accounts secrets
accounts:
  secrets:
    JWT_SECRET: "CHANGE-ME-IN-PRODUCTION"
    DATABASE_PASSWORD: "CHANGE-ME-IN-PRODUCTION"
    OAUTH2_CLIENT_SECRET: "CHANGE-ME-IN-PRODUCTION"
    KEYCLOAK_ISSUER_URI: "https://keycloak.your-domain.com/realms/bank"
    KEYCLOAK_JWK_SET_URI: "https://keycloak.your-domain.com/realms/bank/protocol/openid-connect/certs"

# Cash secrets
cash:
  secrets:
    DATABASE_PASSWORD: "CHANGE-ME-IN-PRODUCTION"
    OAUTH2_CLIENT_SECRET: "CHANGE-ME-IN-PRODUCTION"
    KEYCLOAK_ISSUER_URI: "https://keycloak.your-domain.com/realms/bank"
    KEYCLOAK_JWK_SET_URI: "https://keycloak.your-domain.com/realms/bank/protocol/openid-connect/certs"

# Transfer secrets
transfer:
  secrets:
    DATABASE_PASSWORD: "CHANGE-ME-IN-PRODUCTION"
    OAUTH2_CLIENT_SECRET: "CHANGE-ME-IN-PRODUCTION"
    KEYCLOAK_ISSUER_URI: "https://keycloak.your-domain.com/realms/bank"
    KEYCLOAK_JWK_SET_URI: "https://keycloak.your-domain.com/realms/bank/protocol/openid-connect/certs"

# Notifications secrets
notifications:
  secrets:
    DATABASE_PASSWORD: "CHANGE-ME-IN-PRODUCTION"
    KEYCLOAK_ISSUER_URI: "https://keycloak.your-domain.com/realms/bank"
    KEYCLOAK_JWK_SET_URI: "https://keycloak.your-domain.com/realms/bank/protocol/openid-connect/certs"

# Gateway secrets
gateway:
  secrets:
    JWT_SECRET: "CHANGE-ME-IN-PRODUCTION"
    OAUTH2_CLIENT_SECRET: "CHANGE-ME-IN-PRODUCTION"
    KEYCLOAK_ISSUER_URI: "https://keycloak.your-domain.com/realms/bank"
    KEYCLOAK_JWK_SET_URI: "https://keycloak.your-domain.com/realms/bank/protocol/openid-connect/certs"

# Frontend secrets
frontend:
  secrets:
    OAUTH2_CLIENT_SECRET: "CHANGE-ME-IN-PRODUCTION"
    KEYCLOAK_ISSUER_URI: "https://keycloak.your-domain.com/realms/bank"
    KEYCLOAK_JWK_SET_URI: "https://keycloak.your-domain.com/realms/bank/protocol/openid-connect/certs"

# PostgreSQL secrets
postgresql:
  postgresql:
    password: "CHANGE-ME-IN-PRODUCTION"

# Keycloak secrets
keycloak:
  keycloak:
    adminPassword: "CHANGE-ME-IN-PRODUCTION"
